# =====================================================================
# Sun Serramar Boutique Hostal - Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit .env to git
# =====================================================================

# Gemini AI (Serra Concierge) - get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sunserramar

# Booking notifications recipient
NOTIFICATION_EMAIL_RECIPIENT=contact@sunserramar.com

# SMTP email delivery
SMTP_HOST=smtp.namecheap.com
SMTP_PORT=587
SMTP_USER=contact@sunserramar.com
SMTP_PASSWORD=

# App public URL
APP_URL=https://www.sunserramar.com
