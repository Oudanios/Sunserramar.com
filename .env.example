# =========================================================================
# GEMINI AI CONCIERGE (Serra - powered by Google Gemini)
# =========================================================================
# Your Google Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# =========================================================================
# APP URL
# =========================================================================
# The public URL where this app is hosted (used for Stripe redirects etc.)
APP_URL=https://sunserramar.com

# =========================================================================
# DATABASE (MongoDB Atlas)
# =========================================================================
# Your MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://

# =========================================================================
# STRIPE PAYMENTS
# =========================================================================
# Stripe publishable key (pk_live_ or pk_test_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_
# Stripe secret API key (sk_live_ or sk_test_)
STRIPE_SECRET_KEY=sk_
# Stripe Webhook signing secret (whsec_)
STRIPE_WEBHOOK_SECRET=whsec_

# =========================================================================
# EMAIL (SMTP)
# =========================================================================
# Destination email for booking notifications and contact forms
NOTIFICATION_EMAIL_RECIPIENT=contact@sunserramar.com
# SMTP credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sender@example.com
SMTP_PASSWORD=your-smtp-password
